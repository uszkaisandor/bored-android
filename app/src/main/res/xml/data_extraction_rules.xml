<?xml version="1.0" encoding="utf-8"?><!--
    Backup and device-transfer rules for devices running Android 12 (API 31) and higher.
    Preserves the local favourites database and preferences. Nothing stored is
    sensitive and no data leaves the device beyond the user's own backup.
    See https://developer.android.com/about/versions/12/backup-restore
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
