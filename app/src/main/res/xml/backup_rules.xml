<?xml version="1.0" encoding="utf-8"?><!--
    Auto Backup rules for devices running Android 11 (API 30) and lower.
    Backs up the local favourites database and preferences; the seeded dataset
    is bundled with the app and re-seeded on restore, so it is not backed up.
    See https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <include domain="database" path="." />
    <include domain="sharedpref" path="." />
</full-backup-content>
